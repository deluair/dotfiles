# Managed by ~/dotfiles - do not edit directly
# Machine-specific additions go in ~/.bashrc.local

export PATH="$HOME/.local/bin:$PATH"

# Load machine identity
[ -f "$HOME/dotfiles/config.sh" ] && source "$HOME/dotfiles/config.sh"
export MACHINE_NAME="${MACHINE_NAME:-unknown}"

# uv (Python)
export PATH="$HOME/.cargo/bin:$PATH"

# Aliases
alias dev="cd ~/tradeweave && npm run dev"
alias sites="bash ~/dotfiles/check-sites.sh"
alias backup="bash ~/dotfiles/backup-data.sh"
alias sit="bash ~/dotfiles/bin/sit.sh"
alias standup="bash ~/dotfiles/bin/standup.sh"
alias dr="bash ~/dotfiles/bin/doctor.sh"

# Project shortcuts
alias tw="cd ~/tradeweave"
alias bd="cd ~/bdfacts"
alias om="cd ~/bdpolicylab"

# Source machine-local overrides (untracked)
[ -f ~/.bashrc.local ] && source ~/.bashrc.local
