[include]
	path = ~/.gitconfig.local

[safe]
	directory = *

[claudecode]
	termsAccepted = true

[core]
	editor = code --wait
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
